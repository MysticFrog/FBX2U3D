{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "cargo check",
			"type": "process",
			"command": "${env:USERPROFILE}\\.cargo\\bin\\cargo.exe",
			"args": [
				"check"
			],
			"options": {
				"cwd": "${workspaceFolder}",
				"env": {
					"PATH": "C:\\msys64\\mingw64\\bin;${env:USERPROFILE}\\.cargo\\bin;${env:PATH}"
				}
			},
			"group": "build",
			"problemMatcher": [
				"$rustc"
			]
		},
		{
			"label": "cargo test",
			"type": "process",
			"command": "${env:USERPROFILE}\\.cargo\\bin\\cargo.exe",
			"args": [
				"test"
			],
			"options": {
				"cwd": "${workspaceFolder}",
				"env": {
					"PATH": "C:\\msys64\\mingw64\\bin;${env:USERPROFILE}\\.cargo\\bin;${env:PATH}"
				}
			},
			"group": "test",
			"problemMatcher": [
				"$rustc"
			]
		}
	]
}